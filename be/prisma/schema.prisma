generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique(map: "username") @db.VarChar(50)
  password  String    @db.VarChar(255)
  email     String    @unique(map: "email") @db.VarChar(100)
  avatar    String?   @db.VarChar(255)
  createdAt DateTime? @default(now()) @map("created_at") @db.DateTime(0)
  role      Role?     @default(user)
  phone     String?   @db.VarChar(20)
  address   String?   @db.VarChar(255)

  @@map("users")
}

model cart {
  my_row_id  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  id         Int
  user_id    Int
  product_id Int
  quantity   Int?      @default(1)
  added_at   DateTime? @default(now()) @db.DateTime(0)
}

model categories {
  id   BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  name String @db.VarChar(100)
}

model follows {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  follower_id  Int
  following_id Int
  created_at   DateTime? @default(now()) @db.DateTime(0)
}

model migrations {
  id        BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  migration String @db.VarChar(255)
  batch     Int
}

model order_items {
  my_row_id  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  id         Int
  order_id   Int?
  product_id Int?
  price      Decimal? @db.Decimal(12, 2)
  quantity   Int?
}

model orders {
  my_row_id     BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  id            Int
  user_id       Int?
  total_price   Decimal?       @db.Decimal(12, 2)
  status        orders_status? @default(pending)
  created_at    DateTime?      @default(now()) @db.DateTime(0)
  receiver_name String?        @db.VarChar(100)
  phone         String?        @db.VarChar(20)
  address       String?        @db.VarChar(255)
}

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tokenable_type String    @db.VarChar(255)
  tokenable_id   BigInt    @db.UnsignedBigInt
  name           String    @db.VarChar(255)
  token          String    @db.VarChar(64)
  abilities      String?   @db.Text
  last_used_at   DateTime? @db.Timestamp(0)
  expires_at     DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
}

model post_comments {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id    Int
  user_id    Int
  content    String?   @db.VarChar(300)
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model post_images {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id    Int?
  image_url  String?   @db.VarChar(255)
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model post_likes {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id    Int
  user_id    Int
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model post_shares {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id    Int?
  user_id    Int?
  created_at DateTime? @default(now()) @db.DateTime(0)
}

model posts {
  id            BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  user_id       Int
  caption       String?       @db.Text
  created_at    DateTime?     @default(now()) @db.DateTime(0)
  like_count    Int?          @default(0)
  comment_count Int?          @default(0)
  status        posts_status? @default(active)
}

model product_images {
  id           Int       @id @default(autoincrement())
  product_id   Int
  image_url    String?   @db.VarChar(255)
  is_thumbnail Boolean?  @default(false)
  created_at   DateTime? @default(now()) @db.DateTime(0)
  products     products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_images_ibfk_1")

  @@index([product_id], map: "product_id_idx")
}

model products {
  id             Int              @id
  name           String           @db.VarChar(150)
  price          Decimal          @db.Decimal(12, 2)
  image          String?          @db.VarChar(255)
  description    String?          @db.Text
  category_id    Int
  subcategory_id Int
  location       String?          @db.VarChar(100)
  tag            String?          @db.VarChar(50)
  created_at     DateTime?        @default(now()) @db.DateTime(0)
  stock          Int              @default(10)
  product_images product_images[]

  @@index([category_id], map: "category_id")
  @@index([subcategory_id], map: "subcategory_id")
}

model subcategories {
  id          Int    @id
  name        String @db.VarChar(100)
  category_id Int

  @@index([category_id], map: "category_id")
}

model comments {
  id         Int       @id
  post_id    Int
  user_id    Int
  content    String?   @db.VarChar(300)
  created_at DateTime? @default(now()) @db.DateTime(0)

  @@index([post_id], map: "post_id")
  @@index([user_id], map: "user_id")
}

model likes {
  id         Int       @id
  post_id    Int
  user_id    Int
  created_at DateTime? @default(now()) @db.DateTime(0)

  @@unique([post_id, user_id], map: "unique_like")
  @@index([post_id], map: "post_id")
  @@index([user_id], map: "user_id")
}

enum Role {
  admin
  user
}

enum orders_status {
  pending
  paid
  shipping
  completed
  cancelled
}

enum posts_status {
  active
  hidden
}
